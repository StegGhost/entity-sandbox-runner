{
  "bundle_name": "sandbox_platform_bundle",
  "version": "1.2.0",
  "author": "StegVerse",
  "description": "Sandbox-native installer bundle for control_plane, security_plane, evidence_plane, and observatory",
  "install_mode": "folder_map",
  "allowed_paths": [
    "install/",
    "payload/",
    "bundle_manifest.json",
    "bundle_readme.md"
  ],
  "files": [
    "install/install_platform.py",
    "payload/control_plane/tc/bundle_install.tc.json",
    "payload/control_plane/tvc/verify_bundle_install.py",
    "payload/security_plane/crypto/pq_hash.py",
    "payload/security_plane/crypto/pq_signatures.py",
    "payload/security_plane/crypto/provider.py",
    "payload/security_plane/key_registry/authority_keys.json",
    "payload/evidence_plane/receipt.py",
    "payload/observatory/state_log/record_state.py",
    "bundle_readme.md"
  ]
}